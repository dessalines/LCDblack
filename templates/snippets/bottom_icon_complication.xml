      <Group name="textOnly" x="0" y="0" width="200" height="200" alpha="255">
        <ListConfiguration id="aod_mode">
          <ListOption id="time_only">
            <PartText x="0" y="0" width="112" height="112" alpha="255">
              <Variant mode="AMBIENT" target="alpha" value="0"/>
