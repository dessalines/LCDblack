        </ListConfiguration>
        <ListConfiguration id="aod_mode">
          <ListOption id="time_only">
            <PartText x="0" y="56" width="112" height="20">
              <Variant mode="AMBIENT" target="alpha" value="0"/>
              <Text align="CENTER" ellipsis="TRUE">
