                    <Font family="SYNC_TO_DEVICE" size="28" weight="NORMAL" slant="NORMAL" color="[CONFIGURATION.textColor]">
                      <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                    </Font>
                  </Text>
                </PartText>
              </ListOption>
              <ListOption id="fifty_dimmed">
                <PartText x="0" y="20" width="112" height="20" alpha="255">
                  <Variant mode="AMBIENT" target="alpha" value="127"/>
                  <Text align="CENTER" ellipsis="TRUE">
                    <Font family="SYNC_TO_DEVICE" size="28" weight="NORMAL" slant="NORMAL" color="[CONFIGURATION.textColor]">
                      <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                    </Font>
                  </Text>
                </PartText>
              </ListOption>
              <ListOption id="full">
                <PartText x="0" y="20" width="112" height="20" alpha="255">
                  <Text align="CENTER" ellipsis="TRUE">
                    <Font family="SYNC_TO_DEVICE" size="28" weight="NORMAL" slant="NORMAL" color="[CONFIGURATION.textColor]">
                      <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                    </Font>
                  </Text>
                </PartText>
              </ListOption>
            </ListConfiguration>
            <ListConfiguration id="aod_mode">
              <ListOption id="time_only">
                <PartImage x="40" y="56" width="32" height="32" tintColor="[CONFIGURATION.complicationColor]" alpha="255">
                  <Variant mode="AMBIENT" target="alpha" value="0"/>
                  <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]"/>
                </PartImage>
              </ListOption>
              <ListOption id="twenty_five_dimmed">
                <PartImage x="40" y="56" width="32" height="32" tintColor="[CONFIGURATION.complicationColor]" alpha="255">
