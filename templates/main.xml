<?xml version="1.0"?>
<WatchFace width="450" height="450">
  <Metadata key="CLOCK_TYPE" value="DIGITAL"/>
  <Metadata key="PREVIEW_TIME" value="10:08:32"/>
  <UserConfigurations>
    <ColorConfiguration id="clockColor" defaultValue="0" displayName="clock_color_label" screenReaderText="clock_color_label">
      ${COLORS}
    </ColorConfiguration>
    <ColorConfiguration id="textColor" defaultValue="0" displayName="text_color_label" screenReaderText="text_color_label">
      ${COLORS}
    </ColorConfiguration>
    <ListConfiguration id="aod_mode" displayName="aod_mode_label" icon="string" screenReaderText="aod_mode_label" defaultValue="time_only">
      <ListOption id="time_only" displayName="time_only_label" screenReaderText="time_only_label" icon="string"/>
      <ListOption id="twenty_five_dimmed" displayName="twenty_five_dimmed_label" screenReaderText="twenty_five_dimmed_label" icon="string"/>
      <ListOption id="fifty_dimmed" displayName="fifty_dimmed_label" screenReaderText="fifty_dimmed_label" icon="string"/>
      <ListOption id="full" displayName="full_label" screenReaderText="full_label" icon="string"/>
    </ListConfiguration>
  </UserConfigurations>
  <Scene backgroundColor="#ff000000">
    <DigitalClock x="0" y="0" width="450" height="450">
      <TimeText format="h:mm" hourFormat="SYNC_TO_DEVICE" align="CENTER" x="0" y="0" width="450" height="450" alpha="255">
        <Variant mode="AMBIENT" target="alpha" value="0"/>
        <Font family="d7" size="170" weight="NORMAL" slant="NORMAL" color="[CONFIGURATION.clockColor]"/>
      </TimeText>
      <TimeText format="h:mm" hourFormat="SYNC_TO_DEVICE" align="CENTER" x="0" y="0" width="450" height="450" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255"/>
        <Font family="d7" size="170" weight="LIGHT" slant="NORMAL" color="[CONFIGURATION.clockColor]"/>
      </TimeText>
    </DigitalClock>
    <ComplicationSlot x="46" y="20" width="112" height="112" slotId="1" name="top_left_complication" displayName="top_left" supportedTypes="SHORT_TEXT">
      ${TOP_ICON_COMPLICATION}
    </ComplicationSlot>
    <ComplicationSlot x="158" y="20" width="112" height="112" slotId="2" name="top_complication" displayName="top" supportedTypes="SHORT_TEXT">
      ${TOP_ICON_COMPLICATION}
    </ComplicationSlot>
    <ComplicationSlot x="272" y="20" width="112" height="112" slotId="3" name="top_right_complication" displayName="top_right" supportedTypes="SHORT_TEXT">
      ${TOP_ICON_COMPLICATION}
    </ComplicationSlot>
    <ComplicationSlot x="46" y="300" width="112" height="112" slotId="4" name="bottom_left_complication" displayName="bottom_left" supportedTypes="SHORT_TEXT">
      ${BOTTOM_ICON_COMPLICATION}
    </ComplicationSlot>
    <ComplicationSlot x="158" y="300" width="112" height="112" slotId="5" name="bottom_complication" displayName="bottom" supportedTypes="SHORT_TEXT">
      ${BOTTOM_ICON_COMPLICATION}
    </ComplicationSlot>
    <ComplicationSlot x="272" y="300" width="112" height="112" slotId="6" name="bottom_right_complication" displayName="bottom_right" supportedTypes="SHORT_TEXT">
      ${BOTTOM_ICON_COMPLICATION}
    </ComplicationSlot>
  </Scene>
</WatchFace>
